{
  "name": "@cluion/turing-vue",
  "version": "0.1.0",
  "description": "<Turing> Vue component for the Turing captcha.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "captcha",
    "vue",
    "component",
    "turing-captcha",
    "cluion",
    "turing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cluion/turing.git",
    "directory": "js/packages/vue"
  },
  "homepage": "https://github.com/cluion/turing",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@cluion/turing-element": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^20.10.6",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "vue": "^3.4.0"
  }
}
