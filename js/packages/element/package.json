{
  "name": "@cluion/turing-element",
  "version": "1.0.0",
  "description": "<turing-captcha> custom element for the Turing captcha.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./dist/index.js",
    "./dist/turing-element.global.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./global": "./dist/turing-element.global.js"
  },
  "unpkg": "./dist/turing-element.global.js",
  "jsdelivr": "./dist/turing-element.global.js",
  "files": [
    "dist"
  ],
  "keywords": [
    "captcha",
    "web-component",
    "custom-element",
    "turing-captcha",
    "cluion",
    "turing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cluion/turing.git",
    "directory": "js/packages/element"
  },
  "homepage": "https://github.com/cluion/turing",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@cluion/turing-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "happy-dom": "^20.10.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
