{
  "name": "@cluion/turing-react",
  "version": "0.1.0",
  "description": "<Turing/> React component for the Turing captcha.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "captcha",
    "react",
    "component",
    "turing-captcha",
    "cluion",
    "turing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://git.cluion.com/ningyungame/turing.git",
    "directory": "js/packages/react"
  },
  "homepage": "https://git.cluion.com/ningyungame/turing",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@cluion/turing-element": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.0",
    "happy-dom": "^15.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
