{
  "name": "@cluion/turing-core",
  "version": "0.1.0",
  "description": "Headless client core for the Turing captcha (fetch, PoW, inject).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./dist/index.js",
    "./dist/turing.global.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./global": "./dist/turing.global.js"
  },
  "unpkg": "./dist/turing.global.js",
  "jsdelivr": "./dist/turing.global.js",
  "files": [
    "dist"
  ],
  "keywords": [
    "captcha",
    "pow",
    "proof-of-work",
    "web-crypto",
    "cluion",
    "turing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://git.cluion.com/ningyungame/turing.git",
    "directory": "js/packages/core"
  },
  "homepage": "https://git.cluion.com/ningyungame/turing",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "happy-dom": "^15.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
