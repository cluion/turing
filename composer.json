{
    "name": "cluion/turing",
    "description": "Self-hosted, zero-dependency, cross-language modern captcha with a Laravel integration.",
    "license": "MIT",
    "type": "library",
    "homepage": "https://github.com/cluion/turing",
    "support": {
        "issues": "https://github.com/cluion/turing/issues",
        "source": "https://github.com/cluion/turing"
    },
    "keywords": ["captcha", "pow", "proof-of-work", "laravel", "cluion", "turing"],
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-hash": "*",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Cluion\\Turing\\Core\\": "php/src/Core/",
            "Cluion\\Turing\\Laravel\\": "php/src/Laravel/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cluion\\Turing\\Tests\\Core\\": "php/tests/Core/",
            "Cluion\\Turing\\Tests\\Laravel\\": "php/tests/Laravel/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Cluion\\Turing\\Laravel\\TuringServiceProvider"],
            "aliases": { "Turing": "Cluion\\Turing\\Laravel\\Facade\\Turing" }
        }
    },
    "config": { "sort-packages": true, "allow-plugins": { "*": true } }
}
