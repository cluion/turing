{
    "name": "cluion/turing",
    "description": "Self-hosted, zero-dependency, cross-language modern captcha. Core (framework-agnostic).",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-hash": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": { "Cluion\\Turing\\Core\\": "src/Core/" }
    },
    "autoload-dev": {
        "psr-4": { "Cluion\\Turing\\Tests\\Core\\": "tests/Core/" }
    },
    "config": { "sort-packages": true }
}
