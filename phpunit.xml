<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         cacheDirectory=".phpunit.cache">
  <source>
    <include><directory>php/src</directory></include>
  </source>
  <testsuites>
    <testsuite name="Core"><directory>php/tests/Core</directory></testsuite>
    <testsuite name="Laravel"><directory>php/tests/Laravel</directory></testsuite>
  </testsuites>
</phpunit>
